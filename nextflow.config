// Nextflow requires a `main.nf` and a `nextflow.config` file
// to be present in the repository.
// Actual workflows are in the `src/workflows/` directory.

manifest {
  nextflowVersion = '!>=20.12.1-edge'
}

// Retry tasks that exited with OOM-related signals (137=SIGKILL by oom-killer,
// 139=SIGSEGV often from torch OOM, 140=SIGBUS) so the matrix recovers from
// memory pressure. Ignore everything else so one failing method doesn't kill
// the whole benchmark run. The matching `maxRetries` lives in
// src/workflows/utils/labels.config.
process.errorStrategy = { task.exitStatus in 137..140 ? 'retry' : 'ignore' }

env {
  LD_LIBRARY_PATH = "/home/icb/vladimir.shitov/software/miniconda3/envs/sample_representation_benchmark/lib:$LD_LIBRARY_PATH"
}

trace {
  enabled = true
}
timeline {
  enabled = true
}
report {
  enabled = true
}

profiles {
  standard {
    process.executor = 'slurm'  // Run on cluster by default

    process {
      withLabel: 'gpu' {
        executor = 'slurm'
        queue = 'gpu_p'
        clusterOptions = '--qos=gpu_normal --cpus-per-task=24 --mem=300G --gres=gpu:2 --time=7:59:00 --nice=10000'
      }

      withLabel: 'singlecpu' {
        executor = 'local'
        maxForks = 5
      }

      withLabel: 'highcpu' {
        executor = 'slurm'
        queue = 'cpu_p'
        clusterOptions = '--qos=cpu_normal --cpus-per-task=32 --mem=300G --time=7:59:00 --nice=10000'
      }
    }
  }
}