// Nextflow requires a `main.nf` and a `nextflow.config` file
// to be present in the repository.
// Actual workflows are in the `src/workflows/` directory.

manifest {
  nextflowVersion = '!>=20.12.1-edge'
}

// Retry tasks that exited with OOM-related signals (137=SIGKILL by oom-killer,
// 139=SIGSEGV often from torch OOM, 140=SIGBUS) so the matrix recovers from
// memory pressure. Also retry on 143=SIGTERM and 130=SIGINT so preemptible
// QOS evictions get a second chance. After maxRetries (3, from labels.config)
// fall through to 'ignore' — without this, nextflow's default would terminate
// the entire workflow when a retryable task exhausts retries, killing all
// the other in-flight work for the dataset. Ignore everything else so one
// failing method doesn't kill the whole benchmark run.
process.errorStrategy = {
    def retryable = (task.exitStatus in (137..140)) || (task.exitStatus in [143, 130])
    (retryable && task.attempt <= 3) ? 'retry' : 'ignore'
}

env {
  LD_LIBRARY_PATH = "/home/icb/vladimir.shitov/software/miniconda3/envs/sample_representation_benchmark/lib:$LD_LIBRARY_PATH"
}

trace {
  enabled = true
}
timeline {
  enabled = true
}
report {
  enabled = true
}

profiles {
  standard {
    process.executor = 'slurm'  // Run on cluster by default

    process {
      withLabel: 'gpu' {
        executor = 'slurm'
        queue = 'gpu_p'
        clusterOptions = '--qos=gpu_normal --cpus-per-task=24 --mem=300G --gres=gpu:2 --time=7:59:00 --nice=10000'
      }

      withLabel: 'singlecpu' {
        executor = 'local'
        maxForks = 5
      }

      // diffusionemd is labelled [highmem, lowcpu]. Use cpu_preemptible
      // (200 jobs/user, 3-day wall) so eager driver-side graph expansion
      // doesn't saturate the cpu_normal QOS memory cap and starve the
      // 11 spare_* drivers themselves. 128G fits hlca-scale (1.7M cells);
      // 64G OOM'd. Larger sound_life jobs may still OOM (see below override).
      withLabel: 'lowcpu' {
        executor = 'slurm'
        queue = 'cpu_p'
        clusterOptions = '--qos=cpu_preemptible --cpus-per-task=4 --mem=128G --time=23:59:00 --nice=10000'
      }

      // diffusionemd loads the full processed h5ad in memory before
      // subsampling (sc.read), so memory scales with TOTAL cells, not
      // the subset. sound_life is 13.8M cells (~30G compressed, ~200G
      // uncompressed in scanpy), which OOM'd at 128G. 500G covers it
      // with headroom. cpu_normal instead of preemptible because the
      // load step is single-threaded and slow — losing it to preemption
      // mid-load wastes hours.
      withName: 'diffusionemd_process' {
        executor = 'slurm'
        queue = 'cpu_p'
        clusterOptions = '--qos=cpu_normal --cpus-per-task=4 --mem=500G --time=23:59:00 --nice=10000'
      }

      // Use cpu_preemptible (MaxJobsPU=200, 3-day wall) instead of cpu_normal
      // (100, 1 day) — doubles concurrency. Preempted tasks exit 143/130, which
      // are now in the retry list above.
      withLabel: 'highcpu' {
        executor = 'slurm'
        queue = 'cpu_p'
        clusterOptions = '--qos=cpu_preemptible --cpus-per-task=32 --mem=300G --time=7:59:00 --nice=10000'
      }

      // pilot_gm_vae has runtime O(n_samples^2) and is the long pole on
      // large-sample cohorts (onek1k / imm_of_aging / sound_life). Bumped
      // mem 300G->800G + cpus 24->32 (CPUs help the post-training distance
      // step where it's CPU-bound). gpu_normal QOS caps at 24h; preemption
      // risk on gpu_preemptible is too high here because the VAE doesn't
      // checkpoint, so prefer gpu_normal even at the wall-clock cap.
      withName: 'pilot_gm_vae_process' {
        executor = 'slurm'
        queue = 'gpu_p'
        clusterOptions = '--qos=gpu_normal --cpus-per-task=32 --mem=800G --gres=gpu:2 --time=23:59:00 --nice=10000'
      }

      // mrvi VAE training scales linearly with n_cells; on the largest
      // cohorts (sound_life 13.8M, imm_of_aging 3.8M) extrapolations exceed
      // the 8h default wall from `withLabel: gpu`. Bumped mem 300G->800G
      // and cpus 24->32 for safety. Same 24h budget as pgvae.
      withName: 'mrvi_process' {
        executor = 'slurm'
        queue = 'gpu_p'
        clusterOptions = '--qos=gpu_normal --cpus-per-task=32 --mem=800G --gres=gpu:2 --time=23:59:00 --nice=10000'
      }

      // SampleCLR pretrain is fast per the user (~minutes-tens of minutes),
      // 12 experiments per dataset — biggest GPU consumer by count. Move to
      // gpu_preemptible (MaxJobsPU=50 vs gpu_normal's 16) to unblock the
      // queue. Preemption risk per task is low because each task is short;
      // a preempted task retries via the errorStrategy.
      withName: 'sampleclr_process' {
        executor = 'slurm'
        queue = 'gpu_p'
        clusterOptions = '--qos=gpu_preemptible --cpus-per-task=24 --mem=300G --gres=gpu:1 --time=7:59:00 --nice=10000'
      }

      // Viash auto-generates publishFilesProc / publishStatesProc to copy
      // final outputs to the publish_dir. They have no resource label, so
      // without this they try to submit to Slurm with no queue and fail.
      withName: 'publishFilesProc' {
        executor = 'local'
      }
      withName: 'publishStatesProc' {
        executor = 'local'
      }
    }
  }
}